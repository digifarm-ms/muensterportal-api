# API keys — required, no defaults.
MISTRAL_API_KEY=
TAVILY_API_KEY=

# LLM backend. Default in config.py is "ollama" (expects localhost:11434).
# Production uses "mistral" via the OpenAI-compatible endpoint.
LLM_PROVIDER=mistral

# Reranker. Default in config.py is Alibaba-NLP/gte-multilingual-reranker-base
# (~2.5 GB RSS). On the 7.8 GiB / 0-swap production box the embedder + gte
# reranker OOM-kill the container; switch to the smaller bge model there.
RERANKER_MODEL=BAAI/bge-reranker-base
